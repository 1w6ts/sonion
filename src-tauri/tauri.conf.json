{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xype",
  "version": "0.2.1",
  "identifier": "gg.xype.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "xype",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/motion-runtime": "motion-runtime"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREMzc5MzA4NUQzNkUxRDAKUldUUTRUWmRDSk0zVFFKT0tHYmR3R0ZabVYydUduTzJRQ0FkRlhQdTk0YXZORm5BOHZBaGRaVkkK",
      "endpoints": [
        "https://github.com/1w6ts/sonion/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "xype"
        ]
      }
    }
  }
}